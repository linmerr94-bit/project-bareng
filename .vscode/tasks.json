{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🔄 Rebuild Database (Clean & Migrate)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Set-Location 'd:\\PROJEK UAS E-COMMERCE'; Remove-Item 'db.sqlite3' -Force -ErrorAction SilentlyContinue; Get-ChildItem 'master_products\\migrations' -Filter '*.py' -Exclude '__init__.py' | Remove-Item -Force; python manage.py makemigrations master_products; python manage.py migrate; Write-Host '\u2713 Database rebuilt successfully!' -ForegroundColor Green"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🚀 Run Django Server",
            "type": "shell",
            "command": "python",
            "args": [
                "manage.py",
                "runserver"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "📊 Make Migrations",
            "type": "shell",
            "command": "python",
            "args": [
                "manage.py",
                "makemigrations"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "💾 Migrate Database",
            "type": "shell",
            "command": "python",
            "args": [
                "manage.py",
                "migrate"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
